{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SamuraiWriter7/civilizational-os/schemas/trace-and-royalty-record.schema.json",
  "title": "Trace and Royalty Record",
  "description": "A schema for representing origin traceability, transformation history, attribution routing, value circulation, and governance review in Civilizational OS.",
  "type": "object",

  "required": [
    "record_id",
    "recorded_at",
    "origin",
    "transformation",
    "communication",
    "attribution",
    "royalty",
    "governance"
  ],

  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^tar-[A-Za-z0-9._-]+$"
    },

    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },

    "recorded_by": {
      "type": "string"
    },

    "origin": {
      "type": "object",
      "required": [
        "human_epicenter_id",
        "origin_type",
        "origin_timestamp",
        "origin_description"
      ],
      "properties": {
        "human_epicenter_id": {
          "type": "string",
          "pattern": "^human-origin-[A-Za-z0-9._-]+$"
        },
        "origin_type": {
          "type": "string",
          "enum": [
            "question",
            "design_intent",
            "creative_act",
            "governance_judgment",
            "specification",
            "manuscript",
            "review_decision",
            "policy_intent",
            "research_direction",
            "other"
          ]
        },
        "origin_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "origin_description": {
          "type": "string"
        },
        "origin_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "transformation": {
      "type": "object",
      "required": [
        "transformation_type",
        "input_reference",
        "output_reference"
      ],
      "properties": {
        "engine_id": { "type": "string" },
        "transformation_type": {
          "type": "string",
          "enum": [
            "generation",
            "summarization",
            "translation",
            "classification",
            "specification_generation",
            "code_generation",
            "policy_mapping",
            "governance_review",
            "refinement",
            "derivation",
            "reuse",
            "other"
          ]
        },
        "input_reference": { "type": "string" },
        "output_reference": { "type": "string" },
        "transformation_summary": { "type": "string" }
      },
      "additionalProperties": false
    },

    "communication": {
      "type": "object",
      "required": [
        "sender_type",
        "receiver_type",
        "communication_purpose",
        "communication_scope"
      ],
      "properties": {
        "sender_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_engine",
            "agent",
            "governance_module",
            "external_system",
            "unknown"
          ]
        },
        "receiver_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_engine",
            "agent",
            "governance_module",
            "external_system",
            "public",
            "unknown"
          ]
        },
        "communication_purpose": {
          "type": "string",
          "enum": [
            "generation",
            "refinement",
            "review",
            "validation",
            "publication",
            "reuse",
            "routing",
            "training_reference",
            "governance_decision",
            "other"
          ]
        },
        "communication_scope": {
          "type": "string",
          "enum": [
            "private",
            "internal",
            "limited",
            "public",
            "commercial",
            "governance",
            "ai_to_ai",
            "unknown"
          ]
        },
        "communication_reference": { "type": "string" }
      },
      "additionalProperties": false
    },

    "attribution": {
      "type": "object",
      "required": [
        "contributors",
        "attribution_route"
      ],
      "properties": {
        "contributors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["contributor_id", "role"],
            "properties": {
              "contributor_id": { "type": "string" },
              "role": {
                "type": "string",
                "enum": [
                  "originator",
                  "author",
                  "designer",
                  "reviewer",
                  "validator",
                  "transformer",
                  "agent",
                  "publisher",
                  "maintainer",
                  "other"
                ]
              },
              "contribution_summary": { "type": "string" }
            },
            "additionalProperties": false
          }
        },

        "attribution_route": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },

        "derivative_links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["derivative_id", "relation"],
            "properties": {
              "derivative_id": { "type": "string" },
              "relation": {
                "type": "string",
                "enum": [
                  "derived_from",
                  "refined_from",
                  "summarized_from",
                  "translated_from",
                  "inspired_by",
                  "merged_from",
                  "reused_from",
                  "other"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "royalty": {
      "type": "object",
      "required": [
        "value_flow_type",
        "circulation_required",
        "review_required"
      ],
      "properties": {
        "value_flow_type": {
          "type": "string",
          "enum": [
            "none",
            "attribution_only",
            "attribution_and_review",
            "recognition",
            "reputation",
            "economic_return",
            "royalty_route",
            "access_right",
            "governance_credit",
            "other"
          ]
        },
        "return_route": { "type": "string" },
        "circulation_required": { "type": "boolean" },
        "review_required": { "type": "boolean" },
        "royalty_notes": { "type": "string" }
      },
      "additionalProperties": false
    },

    "governance": {
      "type": "object",
      "required": [
        "validation_status",
        "review_status",
        "boundary_flags",
        "recovery_required"
      ],
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "not_started",
            "pending",
            "passed",
            "failed",
            "warning",
            "not_applicable"
          ]
        },
        "review_status": {
          "type": "string",
          "enum": [
            "not_required",
            "human_review_required",
            "pending",
            "approved",
            "rejected",
            "revision_required"
          ]
        },
        "boundary_flags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "ai_to_ai_reuse",
              "derivative_output",
              "missing_origin",
              "unclear_attribution",
              "value_extraction_risk",
              "governance_boundary",
              "human_review_required",
              "semantic_drift_risk",
              "royalty_required",
              "trace_recovery_required",
              "none"
            ]
          }
        },
        "recovery_required": { "type": "boolean" },
        "related_records": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "governance_notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },

  "additionalProperties": false
}
