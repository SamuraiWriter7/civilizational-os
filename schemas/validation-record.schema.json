{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SamuraiWriter7/civilizational-os/schemas/validation-record.schema.json",
  "title": "Validation Record",
  "description": "A schema for representing validation results, semantic drift detection, hallucination risk, boundary flags, review requirements, and recommended actions in Civilizational OS.",
  "type": "object",

  "required": [
    "record_id",
    "validated_at",
    "target",
    "validation",
    "result",
    "governance"
  ],

  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^val-[A-Za-z0-9._-]+$"
    },

    "validated_at": {
      "type": "string",
      "format": "date-time"
    },

    "validated_by": {
      "type": "string"
    },

    "target": {
      "type": "object",
      "required": [
        "target_id",
        "target_type",
        "target_reference"
      ],
      "properties": {
        "target_id": { "type": "string" },
        "target_type": {
          "type": "string",
          "enum": [
            "ai_generated_text",
            "ai_generated_code",
            "ai_generated_governance_spec",
            "architecture_document",
            "schema",
            "example",
            "trace_record",
            "royalty_record",
            "equilibrium_state",
            "communication_event",
            "policy_recommendation",
            "governance_action",
            "agent_output",
            "workflow",
            "other"
          ]
        },
        "target_reference": { "type": "string" },
        "origin_reference": { "type": "string" }
      },
      "additionalProperties": false
    },

    "validation": {
      "type": "object",
      "required": [
        "validation_types",
        "detected_issues",
        "drift_level",
        "hallucination_risk",
        "boundary_flags",
        "trace_status",
        "attribution_status"
      ],
      "properties": {
        "validation_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "semantic_drift_detection",
              "hallucination_filtering",
              "boundary_checking",
              "trace_consistency_check",
              "attribution_verification",
              "royalty_route_check",
              "schema_validation",
              "constitutional_alignment",
              "multi_agent_cross_verification",
              "human_review_check",
              "governance_action_validation",
              "other"
            ]
          }
        },

        "detected_issues": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "none",
              "semantic_drift_risk",
              "hallucination_risk",
              "unsupported_claim",
              "invalid_schema",
              "missing_origin_trace",
              "trace_incomplete",
              "unclear_attribution",
              "royalty_route_missing",
              "boundary_violation",
              "governance_boundary_risk",
              "human_review_missing",
              "ai_to_ai_recursion",
              "value_extraction_risk",
              "simulated_compliance",
              "policy_drift",
              "over_automation",
              "unsafe_circulation",
              "inconsistent_record",
              "other"
            ]
          }
        },

        "drift_level": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical", "unknown"]
        },

        "hallucination_risk": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical", "unknown"]
        },

        "boundary_flags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "none",
              "human_review_boundary",
              "governance_boundary",
              "attribution_boundary",
              "royalty_boundary",
              "safety_boundary",
              "authority_boundary",
              "execution_boundary",
              "trace_boundary",
              "communication_boundary"
            ]
          }
        },

        "trace_status": {
          "type": "string",
          "enum": ["complete", "partial", "missing", "conflicting", "not_applicable", "unknown"]
        },

        "attribution_status": {
          "type": "string",
          "enum": ["complete", "partial", "missing", "conflicting", "not_applicable", "unknown"]
        },

        "evidence_summary": { "type": "string" },
        "disagreement_summary": { "type": "string" }
      },
      "additionalProperties": false
    },

    "result": {
      "type": "object",
      "required": [
        "validation_result",
        "confidence_level",
        "recommended_actions",
        "review_required",
        "cooling_required",
        "reanchoring_required"
      ],
      "properties": {
        "validation_result": {
          "type": "string",
          "enum": [
            "passed",
            "warning",
            "failed",
            "review_required",
            "revision_required",
            "cooling_required",
            "reanchoring_required",
            "not_applicable"
          ]
        },

        "confidence_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },

        "recommended_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "approve",
              "reject",
              "revise",
              "require_human_review",
              "recover_trace",
              "restore_attribution_route",
              "apply_cooling",
              "pause_circulation",
              "rollback_to_safe_state",
              "cross_verify",
              "escalate_to_policy_review",
              "reanchor_to_human_intent",
              "run_schema_validation",
              "update_boundary_definition",
              "no_action"
            ]
          }
        },

        "review_required": { "type": "boolean" },
        "cooling_required": { "type": "boolean" },
        "reanchoring_required": { "type": "boolean" },

        "correction_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "governance": {
      "type": "object",
      "required": [
        "review_status",
        "final_status"
      ],
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "not_required",
            "human_review_required",
            "pending",
            "approved",
            "rejected",
            "revision_required",
            "escalated"
          ]
        },

        "reviewer": { "type": "string" },

        "final_status": {
          "type": "string",
          "enum": [
            "accepted",
            "accepted_with_warning",
            "blocked",
            "rejected",
            "revision_required",
            "pending_review",
            "pending_recovery",
            "not_finalized"
          ]
        },

        "related_records": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },

        "governance_notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },

  "additionalProperties": false
}
